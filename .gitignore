# =============================================================================
# WealthBot .gitignore
# =============================================================================

# Environment
.env
.env.local
.env.*.local
.env.production
.env.staging
*.env
DEMO_ACCESS.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# ML Models (large files — download-on-startup from object storage)
ml/models/*.pkl
ml/models/*.joblib
ml/models/*.pt
ml/models/*.bin
ml/models/*.onnx
ml/models/*.npy
ml/models/tokenizer.zip
ml/models/tokenizer/
!ml/models/.gitkeep
# feature_config.json must ship with code (single source of truth
# for the train-serve 21-feature contract — see build_feature_config.py)
!ml/models/feature_config.json

# Data (sensitive)
data/
*.csv
*.parquet
*.json
!**/fixtures/*.json
!ml/models/feature_config.json

# Logs
logs/
*.log

# Playwright
.playwright-mcp/
/e2e/
/playwright.config.ts
**/test-results/
**/playwright-report/

# Testing
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# Docker
docker-compose.override.yml

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/

# OS
.DS_Store
Thumbs.db
